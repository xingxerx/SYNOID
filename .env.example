# SYNOID Multi-Provider LLM Configuration
# Copy this file to .env and fill in your API keys.

# ── Groq (Primary LLM – Free Tier) ──────────────────────────────────────────
# Sign up at https://console.groq.com and create an API key.
# Free tier: 1,000 req/day (70B), 14,400 req/day (8B), 30 req/min
GROQ_API_KEY=
# Optional: Override default models
# GROQ_REASONING_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.1-8b-instant

# ── Google AI Studio (Vision – Free Tier) ────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# Free tier (gemini-1.5-flash): 15 req/min, 1,500 req/day, 250K tokens/min
GOOGLE_AI_KEY=
# Optional: Override default vision model
# GOOGLE_VISION_MODEL=gemini-1.5-flash
# Note: gemini-2.5-flash has stricter limits (5-10 RPM, 20-250 RPD)

# ── Ollama / Local Gemma 4 (Primary Sovereign Model) ────────────────────────
# SYNOID defaults to the local, open-source Gemma 4 running in Ollama.
# No cloud API key is required — this is the sovereign, offline path.
#
# Ollama native API base (no /v1 suffix — SYNOID uses /api/chat directly).
SYNOID_API_URL=http://localhost:11434
#
# The model tag SYNOID should ask Ollama for. Must match what you have pulled
# locally (run `ollama list` to check). Default: gemma4:26b.
SYNOID_MODEL=gemma4:26b

# ── AutoResearch — Academic APIs ─────────────────────────────────────────────
# Semantic Scholar API key (optional — unauthenticated requests are rate-limited)
# Sign up at https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex — no API key required (polite pool: add mailto in User-Agent)
# arXiv — no API key required
