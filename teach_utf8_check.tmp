# SYNOID Isolated Instance Launcher v1.2
# Keeps the GUI stable long enough for the autonomous learner to run.

param(
    [int]$port = 3001,
    [double]$restartMinutes = 2,
    [int]$pollSeconds = 5
)

$ErrorActionPreference = "Stop"

Write-Host "Starting Isolated SYNOID Instance on Port $port..." -ForegroundColor Cyan
Write-Host "Build Directory: target_$port" -ForegroundColor Gray
Write-Host "Cargo Home: $PSScriptRoot\target_$port\.cargo" -ForegroundColor Gray
Write-Host "Controlled restart window: every $restartMinutes minute(s) if code changed" -ForegroundColor Gray

# Set environment for Absolute Isolation
$env:CARGO_TARGET_DIR = "target_$port"
$env:CARGO_HOME = "$PSScriptRoot\target_$port\.cargo"
$env:SYNOID_INSTANCE_ID = "$port"
$env:SYNOID_ENABLE_SENTINEL = "true"

$watchRoots = @(
    "src",
    "tests",
    "dashboard",
    "Cargo.toml",
    "Cargo.lock",
    "build.rs",
    "teach.ps1"
)

function Get-WatchSnapshot {
    $entries = New-Object System.Collections.Generic.List[string]

    foreach ($root in $watchRoots) {
        $fullRoot = Join-Path $PSScriptRoot $root
        if (-not (Test-Path $fullRoot)) {
            continue
        }

        $item = Get-Item $fullRoot
        if ($item.PSIsContainer) {
            Get-ChildItem $fullRoot -Recurse -File | ForEach-Object {
                $entries.Add("$($_.FullName)|$($_.LastWriteTimeUtc.Ticks)|$($_.Length)")
            }
        }
        else {
            $entries.Add("$($item.FullName)|$($item.LastWriteTimeUtc.Ticks)|$($item.Length)")
        }
    }

    return ($entries | Sort-Object) -join "`n"
}

function Invoke-SynoidBuild {
    Write-Host "Building release binary..." -ForegroundColor Yellow
    & cargo build --release
    if ($LASTEXITCODE -ne 0) {
        throw "cargo build failed with exit code $LASTEXITCODE"
    }
}

$exePath = Join-Path $PSScriptRoot "target_$port\release\synoid-core.exe"
$lastSnapshot = $null

while ($true) {
    $currentSnapshot = Get-WatchSnapshot
    $needsBuild = ($currentSnapshot -ne $lastSnapshot) -or (-not (Test-Path $exePath))

    if ($needsBuild) {
        Invoke-SynoidBuild
        $lastSnapshot = Get-WatchSnapshot
    }

    Write-Host "Launching GUI on port $port..." -ForegroundColor Green
    $process = Start-Process -FilePath $exePath -ArgumentList @("gui", "--port", "$port") -WorkingDirectory $PSScriptRoot -PassThru -NoNewWindow
    $launchTime = Get-Date
    $restartEligibleAt = $launchTime.AddMinutes($restartMinutes)
    $restartPending = $false

    while (-not $process.HasExited) {
        Start-Sleep -Seconds $pollSeconds
        $process.Refresh()

        $snapshotNow = Get-WatchSnapshot
        if ($snapshotNow -ne $lastSnapshot) {
            $restartPending = $true
        }

        if ($restartPending -and (Get-Date) -ge $restartEligibleAt) {
            Write-Host "Code changes detected. Restarting after $restartMinutes minute(s)..." -ForegroundColor Magenta
            Stop-Process -Id $process.Id -Force
            $process.WaitForExit()
            $lastSnapshot = $null
            break
        }
    }

    if ($process.HasExited -and -not $restartPending) {
        Write-Host "SYNOID exited. Restarting in 5 seconds..." -ForegroundColor Yellow
        Start-Sleep -Seconds 5
    }
}

